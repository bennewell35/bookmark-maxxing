# X MCP/API configuration.
# Do not commit real credentials.

X_MCP_SERVER_URL=https://api.x.com/mcp
X_DOCS_MCP_SERVER_URL=https://docs.x.com/mcp
X_API_BASE_URL=https://api.x.com/2

# Optional, depending on your MCP/API client and auth flow.
X_API_USER_ID=
X_API_BEARER_TOKEN=
X_API_CLIENT_ID=
X_API_CLIENT_SECRET=
X_API_REDIRECT_URI=

# xurl MCP bridge compatibility.
# The official xurl bridge expects CLIENT_ID / CLIENT_SECRET in its environment.
CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URI=http://localhost:8080/callback

# Official X MCP mode (`ingest-x --mcp`).
# Command used to launch the read-only MCP stdio bridge. Defaults to
# "xurl mcp https://api.x.com/mcp". Override to use npx, a custom path, etc.
X_MCP_BRIDGE_COMMAND=
# Read-only MCP tool name for listing bookmarks. Defaults to
# "get_users_id_bookmarks"; discover exact names via the bridge's tools/list.
X_MCP_BOOKMARKS_TOOL=

# `extract --llm` configuration (OpenAI-compatible chat endpoint).
# Defaults target a local Ollama server; works with any OpenAI-compatible
# server (llama.cpp, vLLM, LM Studio, OpenRouter) by overriding base URL/model.
BOOKMARK_MAXXING_LLM_BASE_URL=http://localhost:11434/v1
BOOKMARK_MAXXING_LLM_MODEL=llama3.1
# Only needed for hosted/authenticated endpoints. Leave blank for local Ollama.
BOOKMARK_MAXXING_LLM_API_KEY=
BOOKMARK_MAXXING_LLM_TEMPERATURE=0.2
BOOKMARK_MAXXING_LLM_TIMEOUT=120
